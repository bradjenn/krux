{
  "name": "krux",
  "private": true,
  "version": "0.1.4",
  "description": "A native terminal multiplexer with project management",
  "license": "MIT",
  "main": "dist/main/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/bradjenn/krux"
  },
  "scripts": {
    "dev": "bun run build:main && concurrently -k -n main,renderer \"bun run dev:electron\" \"bun run dev:renderer\"",
    "dev:renderer": "vite",
    "dev:electron": "NODE_ENV=development electron .",
    "build": "bun run build:main && vite build",
    "build:main": "tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json",
    "start": "electron .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "preview": "vite preview",
    "dist": "bun run build && electron-builder --mac",
    "dist:publish": "bun run build && electron-builder --mac --publish always"
  },
  "build": {
    "appId": "com.bradjenn.krux",
    "productName": "Krux",
    "directories": {
      "output": "out"
    },
    "files": [
      "dist/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/node-pty",
        "to": "node_modules/node-pty"
      }
    ],
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools"
    },
    "publish": {
      "provider": "github",
      "owner": "bradjenn",
      "repo": "krux",
      "releaseType": "release"
    },
    "asar": true,
    "asarUnpack": [
      "**/node-pty/**"
    ]
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@hugeicons/core-free-icons": "^3.3.0",
    "@hugeicons/react": "^1.1.5",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@streamdown/code": "^1.0.3",
    "@tailwindcss/vite": "^4.2.1",
    "@xterm/addon-fit": "^0.12.0-beta.193",
    "@xterm/addon-unicode11": "^0.10.0-beta.193",
    "@xterm/addon-webgl": "^0.20.0-beta.192",
    "@xterm/xterm": "^6.1.0-beta.193",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dexie": "^4.3.0",
    "dexie-react-hooks": "^4.2.0",
    "electron-updater": "^6.6.2",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.575.0",
    "mitt": "^3.0.1",
    "node-pty": "^1.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "streamdown": "^2.3.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^11.1.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "electron-builder": "^26.0.12",
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.1.2",
    "electron": "^35.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
